# ------------------------------------------------------------------
# Nisse Group — AI Appointment-Setting Agent
# Copy this file to `.env.local` (Next.js) / `.env` (scripts) and fill in.
# NEVER commit the filled-in file.
# ------------------------------------------------------------------

# --- Vapi (Voice AI) ---
# Private/server API key from https://dashboard.vapi.ai (Org Settings → API Keys).
VAPI_API_KEY=

# The Vapi phone number ID used to place outbound calls (Phone Numbers → your number → ID).
VAPI_PHONE_NUMBER_ID=

# The Vapi assistant ID (created via `npm run assistant:sync`). Optional if you
# pass the inline assistant config on each call instead.
VAPI_ASSISTANT_ID=

# Shared secret used to verify inbound Vapi webhooks. Set the SAME value under
# the assistant's `server.secret` (Vapi sends it back in the `x-vapi-secret` header).
VAPI_WEBHOOK_SECRET=

# --- Supabase (Database) ---
SUPABASE_URL=https://czstsfowxbxlbybhhfxn.supabase.co
# Service-role key — bypasses RLS. Server-side ONLY, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cal.com (Calendar / Booking) ---
# API key from https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=
# Numeric event-type ID for the 15-min discovery call
# (https://cal.com/karel-nijzink/15min → Event Setup → Advanced → shows the ID).
CAL_EVENT_TYPE_ID=

# --- Optional configuration (sane defaults applied in code) ---
# Default IANA timezone for booking / availability lookups.
DEFAULT_TIMEZONE=America/Vancouver
# Delay in milliseconds between outbound calls in the dialer script.
CALL_DELAY_MS=15000
# Max leads to dial in a single run of the dialer (0 = no limit).
CALL_BATCH_LIMIT=0
